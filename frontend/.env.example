# Backend API URL
# Local: http://localhost:8000
# Production: https://vanban-ai-production.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Frontend URL (dùng cho Puppeteer PDF export)
# Local: http://localhost:3000
# Production: https://vanban-ai-one.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Same as NEXT_PUBLIC_APP_URL — required by NextAuth/Puppeteer
NEXTAUTH_URL=http://localhost:3000
