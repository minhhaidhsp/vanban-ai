# Storage backend: "minio" (local dev) | "r2" (production)
STORAGE_BACKEND=minio

# MinIO (local dev) — ignored when STORAGE_BACKEND=r2
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=vanban-ai
MINIO_USE_SSL=false

# Cloudflare R2 (production) — ignored when STORAGE_BACKEND=minio
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=vanban-ai

# Database
# Local: postgresql+asyncpg://postgres:password@localhost:5432/vanban_ai
# Supabase: postgresql+asyncpg://postgres.PROJECT_REF:PWD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/vanban_ai

# Redis
# Local: redis://localhost:6379
# Upstash: rediss://default:PWD@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379

# LLM — Groq API (dùng chung dev/production)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL_NAME=llama-3.3-70b-versatile

# Auth
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000"]

# OCR cho PDF scan (tùy chọn — bỏ qua nếu không cần đọc PDF scan)
# Windows: cài tesseract tại https://github.com/UB-Mannheim/tesseract/wiki
#   - Chọn "Vietnamese" language pack khi cài
#   - Thêm vào PATH: C:\Program Files\Tesseract-OCR
# Linux/Docker: apt-get install tesseract-ocr tesseract-ocr-vie poppler-utils
# TESSERACT_CMD=tesseract  # để trống = dùng PATH mặc định
